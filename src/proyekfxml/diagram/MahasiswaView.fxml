<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<!--
  SplitPane membagi stage menjadi 2 bagian:
   - KIRI  : TableView berisi data mahasiswa
   - KANAN : BarChart yang menampilkan nilai
  dividerPositions="0.5" -> garis pemisah tepat di tengah (bisa digeser).
-->

<SplitPane dividerPositions="0.5" prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyekfxml.diagram.MahasiswaController">
    <items>

        <!-- ============ BAGIAN KIRI: TABEL ============ -->
        <VBox prefHeight="619.0" prefWidth="463.0" spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Data Mahasiswa" />

                <TableView fx:id="tabelMahasiswa" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="kolomNim" prefWidth="110.0" text="NIM" />
                        <TableColumn fx:id="kolomNama" prefWidth="160.0" text="Nama" />
                        <TableColumn fx:id="kolomNilai" prefWidth="90.0" text="Nilai" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <!-- ============ BAGIAN KANAN: DIAGRAM ============ -->
        <VBox prefHeight="624.0" prefWidth="510.0" spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Diagram Nilai" />

                <BarChart fx:id="diagramNilai" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis fx:id="sumbuX" label="Nama Mahasiswa" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="sumbuY" autoRanging="false" label="Nilai" lowerBound="0" tickUnit="10" upperBound="100" />
                    </yAxis>
                </BarChart>
            </children>
        </VBox>

    </items>
</SplitPane>
